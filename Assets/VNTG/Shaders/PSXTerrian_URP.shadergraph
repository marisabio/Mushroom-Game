{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "53239693a7cf4596a14a15a2178905b6",
    "m_Title": "Note",
    "m_Content": "No unlit terrian shader in Unity 6.3.\n\nUntill I can find a work around I set metallic to 1 if UNLIT to avoid additional lights from making the material glow.\n\nI set metallic to 0 if LIT so the enviroment lighting doesnt diffuse across the surface. Unity lighting will still apply here but it will be overshadowed by PSX lighting.\n\nIf there is no main light in the scene, the enviroment ambient lighting will still be noticable on the terrian so it's best to disabled that in the lighting settings for the time being. ",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 2839.0,
        "y": 834.0,
        "width": 214.0,
        "height": 285.0
    },
    "m_Group": {
        "m_Id": "057959ec66ff4793b84fe8f9227d9d25"
    }
}

