{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "6602c3a92c6646b4a33a3e499de3a823",
    "m_Title": "Note",
    "m_Content": "If vertex jitter mode is set to Screen Space shaodws will get exteremly messed up due to the light camera observing drastically different jitter than the player.\n\nTo avoid this if vertex jitter mode is set to Screen Space I render the material with no jitter in the Shadow Pass.\n\nAs a result in Screen Space jitter mode shadows won't jitter but this is the lesser of two evils. ",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 1535.0,
        "y": -1431.0,
        "width": 198.0,
        "height": 231.0
